<!-- ============================================================
     FILE: dashboard/views/beranda.ejs
     FUNGSI: Halaman Beranda — landing page + online user panel
     ALUR: GET /beranda → controller → render halaman ini

     FITUR:
       - Sambutan + info user
       - Modul tersedia (kartu grid)
       - Panel user online (filtered by role hierarchy, real-time)
     ============================================================ -->
<%- include('../../src/views/layout_header') %>

    <!-- ====================================================
         1) HALO USER — tipis, ringan
         ==================================================== -->
    <!-- <div class="beranda-halo">
        Halo, <strong><%= user.nama_pengguna %></strong>
        <span class="badge badge-<%= user.jabatan.toLowerCase() %>" style="margin-left: 6px; vertical-align: middle;"><%= user.jabatan === 'ASIST_MANAGER' ? 'ASIST MANAGER' : user.jabatan %></span>
        <% if (atasan) { %>
            <span class="beranda-halo-atasan">— Atasan: <%= atasan.nama_pengguna %></span>
        <% } %>
        <% if (jumlahApproval > 0) { %>
            <a href="/mutasi/approval" class="beranda-halo-notif" title="Request mutasi menunggu">
                &#9888; <%= jumlahApproval %> request
            </a>
        <% } %>
    </div> -->

    <% if (belumPunyaAtasan) { %>
    <!-- ====================================================
         RESTRICTED: User belum punya atasan
         ==================================================== -->
    <div style="max-width: 600px; margin: 60px auto; text-align: center;">
        <div style="background: linear-gradient(135deg, #f0f8ff 0%, #e8f5e9 100%); border-radius: 16px; padding: 40px 30px; box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
            <div style="font-size: 3rem; margin-bottom: 12px;">&#128075;</div>
            <h2 style="color: #2c3e50; margin: 0 0 8px 0; font-size: 1.5rem;">
                Welcome, <%= user.nama_pengguna %>!
            </h2>
            <p style="color: #7f8c8d; font-size: 1rem; margin: 0 0 24px 0;">
                Anda login sebagai <strong><%= user.jabatan === 'ASIST_MANAGER' ? 'Asisten Manager' : user.jabatan %></strong>
            </p>
            <div style="background: #fff3cd; border: 1px solid #ffc107; border-radius: 8px; padding: 16px; text-align: left; margin-bottom: 20px;">
                <p style="margin: 0; color: #856404; font-size: 0.92rem;">
                    &#9888; <strong>Anda belum memiliki atasan.</strong><br>
                    Wajib isi atasan (<%= VALID_PARENT_ROLE[user.jabatan] %>) agar bisa beraktivitas. Silakan ajukan permintaan melalui menu Mutasi.
                </p>
            </div>
            <a href="/mutasi" class="btn btn-primary" style="padding: 10px 28px; font-size: 0.95rem;">
                &#8693; Ajukan Atasan Sekarang
            </a>
        </div>
    </div>
    <% } else { %>

    <!-- ====================================================
         2) IMAGE SLIDER / CAROUSEL
         ==================================================== -->
    <% if (sliderImages.length > 0) { %>
    <div class="beranda-slider">
        <div class="beranda-slider-track" id="sliderTrack">
            <% sliderImages.forEach(function(src, idx) { %>
            <div class="beranda-slide<%= idx === 0 ? ' active' : '' %>">
                <img src="<%= src %>" alt="Slide <%= idx + 1 %>" draggable="false">
            </div>
            <% }); %>
        </div>

        <% if (sliderImages.length > 1) { %>
        <button class="beranda-slider-btn beranda-slider-prev" onclick="sliderNav(-1)" aria-label="Previous">&#10094;</button>
        <button class="beranda-slider-btn beranda-slider-next" onclick="sliderNav(1)" aria-label="Next">&#10095;</button>
        <div class="beranda-slider-dots" id="sliderDots">
            <% sliderImages.forEach(function(src, idx) { %>
            <span class="beranda-slider-dot<%= idx === 0 ? ' active' : '' %>" onclick="sliderGo( <%= idx %> )"></span>
            <% }); %>
        </div>
        <% } %>
    </div>

    <script>
    (function() {
        var current   = 0;
        var slides    = document.querySelectorAll('.beranda-slide');
        var dots      = document.querySelectorAll('.beranda-slider-dot');
        var total     = slides.length;
        var autoTimer = null;

        function show(idx) {
            if (total <= 1) return;
            slides[current].classList.remove('active');
            if (dots[current]) dots[current].classList.remove('active');
            current = (idx + total) % total;
            slides[current].classList.add('active');
            if (dots[current]) dots[current].classList.add('active');
        }

        window.sliderNav = function(dir) {
            show(current + dir);
            resetAuto();
        };
        window.sliderGo = function(idx) {
            show(idx);
            resetAuto();
        };

        function autoPlay() {
            autoTimer = setInterval(function() { show(current + 1); }, 5000);
        }
        function resetAuto() {
            clearInterval(autoTimer);
            autoPlay();
        }
        if (total > 1) autoPlay();
    })();
    </script>
    <% } %>

    <!-- ====================================================
         3) DAFTAR MODUL
         ==================================================== -->
    <div class="beranda-section">
        <h3 class="beranda-section-title">Promo Terbaru</h3>

        <% if (modulTersedia.length === 0) { %>
            <div class="beranda-empty">
                <p>Belum ada promo yang tersedia untuk level akses Anda.</p>
            </div>
        <% } else { %>
            <div class="beranda-modul-grid">
                <% modulTersedia.forEach(function(modul) { %>
                    <a href="<%= modul.url %>" class="beranda-modul-card">
                        <div class="beranda-modul-icon <%= modul.warna %>">
                            <%- modul.ikon %>
                        </div>
                        <div class="beranda-modul-info">
                            <h4 class="beranda-modul-nama"><%= modul.nama %></h4>
                            <p class="beranda-modul-desc"><%= modul.deskripsi %></p>
                        </div>
                        <span class="beranda-modul-arrow">&#10132;</span>
                    </a>
                <% }); %>
            </div>
        <% } %>
    </div>

    <!-- ====================================================
         4) USER ONLINE: Panel real-time (filtered by role)
         ==================================================== -->
    <div class="section" style="margin-top: 20px;">
        <h3 class="section-title">&#9679; Tim Online</h3>
        <div class="online-role-grid" id="onlineRoleGrid">
            <!-- Kartu role akan di-render oleh JavaScript -->
        </div>
    </div>

    <!-- ====================================================
         SCRIPT: Online panel untuk user biasa
         ==================================================== -->
    <script>
        var onlineData = { counts: {}, details: [] };
        var openRoles  = {};
        var myJabatan  = '<%= user.jabatan %>';

        // Toggle expand/collapse
        function toggleRoleDetail(role) {
            var el    = document.getElementById('detail_' + role);
            var arrow = document.getElementById('arrow_' + role);
            if (!el) return;

            if (el.style.display === 'none') {
                el.style.display = 'block';
                arrow.innerHTML  = '&#9650;';
                openRoles[role]  = true;
                renderRoleDetail(role);
            } else {
                el.style.display = 'none';
                arrow.innerHTML  = '&#9660;';
                openRoles[role]  = false;
            }
        }

        function renderRoleDetail(role) {
            var container = document.getElementById('list_' + role);
            if (!container) return;

            var users = onlineData.details.filter(function(u) {
                return u.jabatan === role;
            });

            if (users.length === 0) {
                container.innerHTML = '<p class="text-muted">Tidak ada user online.</p>';
                return;
            }

            var html = '<table class="data-table data-table-sm">';
            html += '<thead><tr><th>Nama</th><th>Status</th><th>Device</th></tr></thead>';
            html += '<tbody>';
            for (var i = 0; i < users.length; i++) {
                var u  = users[i];
                var ua = parseDevice(u.user_agent || '');
                html += '<tr>';
                html += '<td><span class="online-dot"></span> ' + escapeHtml(u.nama_pengguna) + '</td>';
                html += '<td><span class="badge badge-success">Online</span></td>';
                html += '<td class="detail-cell">' + escapeHtml(ua) + '</td>';
                html += '</tr>';
            }
            html += '</tbody></table>';
            container.innerHTML = html;
        }

        // Render kartu role & update angka
        function updateOnlineUI(data) {
            onlineData = data;
            var roles  = Object.keys(data.counts);
            var grid   = document.getElementById('onlineRoleGrid');
            if (!grid) return;

            // Cek apakah kartu sudah ada (update saja angkanya)
            var existing = document.getElementById('count_' + (roles[0] || ''));
            if (existing) {
                // Update angka saja
                for (var i = 0; i < roles.length; i++) {
                    var role  = roles[i];
                    var count = data.counts[role] || 0;
                    var el    = document.getElementById('count_' + role);
                    if (el) el.textContent = count;
                    if (openRoles[role]) renderRoleDetail(role);
                }
                return;
            }

            // Pertama kali: buat kartu
            var html = '';
            for (var j = 0; j < roles.length; j++) {
                var r = roles[j];
                var c = data.counts[r] || 0;
                html += '<div class="online-role-card" data-role="' + r + '" onclick="toggleRoleDetail(\'' + r + '\')">';
                html += '  <div class="online-role-icon role-icon-' + r.toLowerCase() + '">';
                html += '    <span class="online-role-count" id="count_' + r + '">' + c + '</span>';
                html += '  </div>';
                html += '  <div class="online-role-label">' + r + '</div>';
                html += '  <div class="online-role-arrow" id="arrow_' + r + '">&#9660;</div>';
                html += '</div>';
                html += '<div class="online-role-detail" id="detail_' + r + '" style="display:none;">';
                html += '  <div class="online-role-detail-inner" id="list_' + r + '">';
                html += '    <p class="text-muted">Tidak ada user online.</p>';
                html += '  </div>';
                html += '</div>';
            }
            grid.innerHTML = html;
        }

        function parseDevice(ua) {
            if (!ua) return '-';
            if (ua.indexOf('Mobile') !== -1 || ua.indexOf('Android') !== -1) return 'Mobile';
            if (ua.indexOf('Windows') !== -1) return 'Windows';
            if (ua.indexOf('Mac') !== -1) return 'Mac';
            if (ua.indexOf('Linux') !== -1) return 'Linux';
            return 'Browser';
        }

        function escapeHtml(text) {
            var div = document.createElement('div');
            div.appendChild(document.createTextNode(text));
            return div.innerHTML;
        }

        // Ambil data awal via API (backend sudah filter by role)
        fetch('/api/online-users')
            .then(function(r) { return r.json(); })
            .then(function(data) { updateOnlineUI(data); });

        // Auto-refresh Tim Online setiap 60 detik
        // Sinkron dengan heartbeat — tangkap perubahan online/offline
        setInterval(function() {
            fetch('/api/online-users')
                .then(function(r) { return r.json(); })
                .then(function(data) { updateOnlineUI(data); });
        }, 60000);
    </script>

    <% } /* end else: belumPunyaAtasan */ %>

<%- include('../../src/views/layout_footer') %>

<!-- CSS khusus dashboard -->
<link rel="stylesheet" href="/dashboard/css/dashboard.css">
