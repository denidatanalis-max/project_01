            <h4 style="font-size: 0.9rem; color: #2c3e50; margin-bottom: 8px;">Riwayat Upload LBP</h4>
            <div class="table-wrapper">
                <table class="data-table data-table-sm">
                    <thead>
                        <tr><th>No</th><th>Nama File</th><th>Tanggal Upload</th><th>Aksi</th></tr>
                    </thead>
                    <tbody>
                        <% riwayatLBP.forEach(function(r, i) { %>
                        <tr>
                            <td><%= i + 1 %></td>
                            <td><%= r.nama_file %></td>
                            <td class="nowrap"><%= r.uploaded_at %></td>
                            <td>
                                <form method="POST" action="/sa/upload-data/hapus-lbp" style="display:inline;"
                                      onsubmit="return confirm('Hapus data LBP ini?')">
                                    <input type="hidden" name="upload_id" value="<%= r.id %>">
                                    <button type="submit" class="btn btn-sm btn-danger">Hapus</button>
                                </form>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
        <% } %>
    </div>

    <!-- ====================================================
         UPLOAD STOCK
         ==================================================== -->
    <div class="section sa-upload-section">
        <h3 class="section-title">&#128230; Upload Stock</h3>
        <p style="font-size: 0.88rem; color: #7f8c8d; margin-bottom: 14px;">
