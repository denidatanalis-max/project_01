            <h4 style="font-size: 0.9rem; color: #2c3e50; margin-bottom: 8px;">Riwayat Upload Stock</h4>
            <div class="table-wrapper">
                <table class="data-table data-table-sm">
                    <thead>
                        <tr><th>No</th><th>Nama File</th><th>Tanggal Upload</th><th>Aksi</th></tr>
                    </thead>
                    <tbody>
                        <% riwayatStock.forEach(function(r, i) { %>
                        <tr>
                            <td><%= i + 1 %></td>
                            <td><%= r.nama_file %></td>
                            <td class="nowrap"><%= r.uploaded_at %></td>
                            <td>
                                <form method="POST" action="/sa/upload-data/hapus-stock" style="display:inline;"
                                      onsubmit="return confirm('Hapus data Stock ini?')">
                                    <input type="hidden" name="upload_id" value="<%= r.id %>">
                                    <button type="submit" class="btn btn-sm btn-danger">Hapus</button>
                                </form>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
        <% } %>
    </div>

<%- include('../../src/views/layout_footer') %>
